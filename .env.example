# Environment Configuration
ENVIRONMENT=development

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fhir_dicom_dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fhir_dicom_dev
DB_USER=postgres
DB_PASSWORD=postgres

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# FHIR Configuration
FHIR_SERVER_BASE=http://localhost:8080/fhir

# DICOM Configuration
DICOM_STORAGE_PATH=./data/dicom

# Med-Gemma Configuration
MEDGEMMA_MODEL=google/medgemma-7b
MEDGEMMA_MODEL_PATH=./models/medgemma
DEVICE=auto

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
API_KEY=your-api-key-change-in-production

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# External Services
HUGGINGFACE_TOKEN=your-huggingface-token-here

# Application
PORT=8000
HOST=0.0.0.0